{
  "manifest_version": 3,
  "name": "VGTC Order & Factory Voucher Sync",
  "version": "1.0.0",
  "description": "Auto-extract orders from JK Super Cement portal and create Factory Vouchers instantly in VGTC Software.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.jkcement.com/*",
    "http://localhost:5000/*",
    "http://localhost:5173/*",
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.jkcement.com/*",
        "*://*/*order*",
        "*://*/*voucher*",
        "*://*/*dispatch*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
