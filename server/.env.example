# ══════════════════════════════════════════════════════════════════
# VGTC Management Server — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is in .gitignore).
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
# ENVIRONMENT TIER (Required)
# ──────────────────────────────────────────────────────────────────
# Controls which Firestore collections this server reads/writes to.
#
#  local      → Writes to "dev_*" collections on your machine
#  beta       → Writes to "beta_*" collections on Netlify branch deploys
#  production → Writes to bare collections on Netlify main deploy
#
# On Netlify: set automatically via netlify.toml [context.*.environment]
# Locally: always keep as 'local'  ← DO NOT set to 'production' locally!
APP_ENV=local

# Set to 'true' to fully block write operations when not in production.
# Useful for read-only inspection of data in another environment.
BLOCK_PROD_WRITES=false

# ──────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ──────────────────────────────────────────────────────────────────
JWT_SECRET=vgtc-secret-2026

# ──────────────────────────────────────────────────────────────────
# SMTP — OTP Email Sending
# ──────────────────────────────────────────────────────────────────
# For Gmail: create an "App Password" in Google Account Security settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ──────────────────────────────────────────────────────────────────
# FIREBASE (Optional — falls back to local JSON if not provided)
# ──────────────────────────────────────────────────────────────────
# Local: place serviceAccountKey.json in server/ directory
# Netlify: paste the entire JSON content as a single-line string below
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
